generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(uuid())
  telegramId           String    @unique
  username             String?
  clickBalance         Float     @default(0) @map("kvnc_balance")
  kunaBalance          Float     @default(0) @map("kuna_balance")
  energy               Int       @default(1000)
  maxEnergy            Int       @default(1000) @map("max_energy")
  lastEnergyUpdate     DateTime  @default(now()) @map("last_energy_update")
  activePickaxeRarity  String    @default("COMMON") @map("active_pickaxe_rarity")
  tonWallet            String?   @map("ton_wallet")
  totalClicks          Int       @default(0) @map("total_clicks")
  dailyClicks          Int       @default(0) @map("daily_clicks")
  lastClickDate        DateTime  @default(now()) @map("last_click_date")
  referredBy           String?   @map("referred_by")
  referralCount        Int       @default(0) @map("referral_count")
  lastBonusDate        DateTime? @map("last_bonus_date")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  nfts        NFT[]
  withdrawals Withdrawal[]
  quests      Quest[]

  referredByUser User?  @relation("UserReferrals", fields: [referredBy], references: [id])
  referrals      User[] @relation("UserReferrals")

  @@map("users")
}

model NFT {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  tokenId         Int       @map("token_id")
  contractAddress String    @map("contract_address")
  rarity          String
  name            String
  image           String
  bonusMultiplier Float     @default(1) @map("bonus_multiplier")
  mintReward      Float     @default(0) @map("mint_reward")
  requiredClicks  Int       @default(0) @map("required_clicks")
  mintedAt        DateTime  @default(now()) @map("minted_at")
  equipped        Boolean   @default(false)
  maxSupply       Int       @default(100) @map("max_supply")
  totalMinted     Int       @default(0) @map("total_minted")
  stakeEndDate    DateTime? @map("stake_end_date")
  stakeStartDate  DateTime? @map("stake_start_date")
  staked          Boolean   @default(false)
  stakingReward   Float     @default(0.1) @map("staking_reward")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nfts")
}

model Withdrawal {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id")
  amount      Float
  status      String    @default("pending")
  tonAddress  String    @map("ton_address")
  requestedAt DateTime  @default(now()) @map("requested_at")
  processedAt DateTime? @map("processed_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("withdrawals")
}

model Quest {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id")
  type        String
  target      Int
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  reward      Float
  questDate   DateTime  @map("quest_date")
  completedAt DateTime? @map("completed_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, questDate])
  @@map("quests")
}

model PoolTracking {
  id             Int      @id @default(autoincrement())
  poolName       String   @unique @map("pool_name")
  totalAllocated Float    @map("total_allocated")
  spent          Float    @default(0)
  remaining      Float    @default(0)
  lastUpdated    DateTime @default(now()) @map("last_updated")

  @@map("pool_tracking")
}

model PriceHistory {
  id        Int      @id @default(autoincrement())
  usdt      Float
  gram      Float
  volume24h Float
  liquidity Float
  marketCap Float
  createdAt DateTime @default(now())

  @@index([createdAt])
}
