<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Kovanica Rudnik</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link rel="stylesheet" href="style.css?v=5" />
</head>
<body>
    <div id="particleContainer"></div>
    <div id="app">

        <!-- HEADER -->
        <div class="header">
            <div class="user-row">
                <div class="user-left">
                    <div class="avatar" id="avatar">R</div>
                    <div class="user-info">
                        <span class="username" id="username">Rudar</span>
                        <span class="rank-badge" id="rankBadge">🪨 Novi rudar</span>
                <span class="streak-badge" id="streakBadge">🔥 0d</span>
                    </div>
                </div>
                <div class="header-right">
                    <button class="sound-btn" id="soundBtn" onclick="toggleSound()">🔊</button>
                    <div class="balance-block">
                        <span class="balance" id="balance">0.0000</span>
                        <span class="currency">KVNC</span>
                    </div>
                </div>
            </div>


        <!-- TON CONNECT -->
        <div class="ton-connect-wrap" id="tonConnectWrap">
            <div id="ton-connect"></div>
        </div>

            <!-- RANK PROGRESS -->
            <div class="rank-progress-wrap">
                <div class="rank-progress-fill" id="rankProgressFill" style="width:0%"></div>
            </div>
            <div class="rank-progress-text" id="rankProgressText">0 / 100</div>

            <!-- BOOST TIMER -->
            <div class="boost-bar" id="boostBar" style="display:none">
                <span class="boost-label">⚡ 2x BOOST</span>
                <div class="boost-progress-wrap">
                    <div class="boost-progress" id="boostProgress"></div>
                </div>
                <span class="boost-time" id="boostTime">10:00</span>
            </div>

            <!-- ENERGY BAR -->
            <div class="energy-wrap">
                <div class="energy-header">
                    <span class="energy-label">⚡ Energija</span>
                    <span class="energy-val" id="energyVal">1000 / 1000</span>
                </div>
                <div class="energy-bar-bg">
                    <div class="energy-bar-fill" id="energyFill" style="width:100%"></div>
                </div>
                <div class="energy-countdown" id="energyCountdown">⚡ Energija puna!</div>
            </div>
        </div>

        <!-- TAB NAVIGATION -->
        <div class="tabs">
            <button class="tab active" data-tab="mine" onclick="switchTab('mine')">⛏️ Rudnik</button>
            <button class="tab" data-tab="nft" onclick="switchTab('nft')">🎨 NFT</button>
            <button class="tab" data-tab="quests" onclick="switchTab('quests')">📋 Zadaci</button>
            <button class="tab" data-tab="leaderboard" onclick="switchTab('leaderboard')">🏆 Top</button>
            <button class="tab" data-tab="referral" onclick="switchTab('referral')">👥 Ref</button>
            <button class="tab" data-tab="wallet" onclick="switchTab('wallet')">💎 Wallet</button>
        <!-- TAB: MINE -->
        <div class="tab-content active" id="tab-mine">
            <div class="stats-row">
                <div class="stat-item">
                    <span class="stat-label">👆 Ukupno</span>
                    <span class="stat-value" id="totalClicks">0</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">📅 Danas</span>
                    <span class="stat-value" id="dailyClicks">0</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">⭐ Nagrada</span>
                    <span class="stat-value" id="rewardPerTap">1 KVNC</span>
                </div>
            </div>

            <div class="mine-area">
                <div class="pickaxe-wrapper" id="pickaxeWrapper">
                    <div class="pickaxe-glow"></div>
                    <div class="pickaxe" id="pickaxe">⛏️</div>
                </div>
                <div class="click-counter" id="clickCounter">+1</div>
                <button class="mine-btn" id="mineBtn">
                    <span class="btn-text">⛏️ RUDARI!</span>
                    <span class="btn-sub" id="rewardSub">+1 KVNC po kliku</span>
                </button>
                <button class="boost-btn" id="boostBtn" onclick="handleBoost()">
                    ⚡ Aktiviraj 2x Boost
                </button>
            </div>
        </div>

        <!-- TAB: NFT -->
        <div class="tab-content" id="tab-nft">
            <div class="nft-header">
                <div class="nft-equipped" id="nftEquipped">
                    <span class="nft-eq-label">Opremljeni NFT</span>
                    <div class="nft-eq-empty" id="nftEqEmpty">
                        <span>Nema opremljenog NFT-a</span>
                        <span class="nft-eq-hint">Opremi NFT za bonus rudarenja!</span>
                    </div>
                    <div class="nft-eq-card" id="nftEqCard" style="display:none">
                        <span class="nft-eq-icon" id="nftEqIcon">⛏️</span>
                        <div>
                            <span class="nft-eq-name" id="nftEqName">-</span>
                            <span class="nft-eq-bonus" id="nftEqBonus">1x bonus</span>
                        </div>
                        <button class="nft-unequip-btn" onclick="handleUnequip()">Skini</button>
                    </div>
                </div>
            </div>
            <div class="nft-section-label">Tvoji NFT-ovi</div>
            <div class="nft-grid" id="nftGrid">
                <div class="nft-loading">Učitavanje NFT-ova...</div>
            </div>
            <div class="nft-info">
                <div class="nft-info-row"><span>⛏️ Brončani pijuk</span><span class="nft-bonus-tag">1.2x</span></div>
                <div class="nft-info-row"><span>🥈 Srebrni pijuk</span><span class="nft-bonus-tag">1.5x</span></div>
                <div class="nft-info-row"><span>🥇 Zlatni pijuk</span><span class="nft-bonus-tag">2.0x</span></div>
                <div class="nft-info-row"><span>💎 Dijamantni pijuk</span><span class="nft-bonus-tag">3.0x</span></div>
                <div class="nft-info-row"><span>🔥 Vatreni pijuk</span><span class="nft-bonus-tag">5.0x</span></div>
            </div>
        </div>

        <!-- TAB: QUESTS -->
        <div class="tab-content" id="tab-quests">
            <div class="quest-title-main">📋 Dnevni zadaci</div>
            <div class="quest-list" id="questList">
                <div class="lb-loading">Učitavanje zadataka...</div>
            </div>
        </div>

        <!-- TAB: LEADERBOARD -->
        <div class="tab-content" id="tab-leaderboard">
            <div class="lb-title">🏆 Top Rudari</div>
            <div class="lb-list" id="lbList">
                <div class="lb-loading">Učitavanje...</div>
            </div>
            <div class="lb-my-rank" id="lbMyRank" style="display:none">
                <span>Tvoj rang: </span><span id="myRankNum">#-</span>
            </div>
        </div>

        <!-- TAB: REFERRAL -->
        <div class="tab-content" id="tab-referral">
            <div class="ref-card">
                <div class="ref-title">👥 Pozovi prijatelje</div>
                <div class="ref-desc">Za svakog novog korisnika dobit ćeš <strong>10 KVNC</strong>!</div>
                <div class="ref-stats">
                    <div class="ref-stat">
                        <span class="ref-stat-val" id="refCount">0</span>
                        <span class="ref-stat-label">Pozvanih</span>
                    </div>
                    <div class="ref-stat">
                        <span class="ref-stat-val" id="refEarned">0</span>
                        <span class="ref-stat-label">Zarađeno KVNC</span>
                    </div>
                </div>
                <div class="ref-link-wrap">
                    <span class="ref-link-label">Tvoj link:</span>
                    <div class="ref-link-box" id="refLink">Učitavanje...</div>
                </div>
                <button class="ref-copy-btn" onclick="copyRefLink()">📋 Kopiraj link</button>
                <button class="ref-share-btn" onclick="shareRefLink()">📤 Podijeli</button>
            </div>
            <div class="ref-lb-title">🏆 Referral ljestvica</div>
            <div class="ref-lb-list" id="refLbList">
                <div class="lb-loading">Učitavanje...</div>
            </div>
        </div>


        <!-- TAB: WALLET -->
        <div class="tab-content" id="tab-wallet">
            <div class="wallet-card">
                <div class="wallet-title">💎 TON Wallet</div>
                <div class="wallet-address-wrap">
                    <span class="wallet-label">Adresa</span>
                    <span class="wallet-addr" id="walletAddress">Nije spojen</span>
                </div>
                <div class="wallet-balances">
                    <div class="wallet-bal-item">
                        <span class="wallet-bal-label">💎 TON</span>
                        <span class="wallet-bal-val" id="tonBalance">0 TON</span>
                    </div>
                    <div class="wallet-bal-item">
                        <span class="wallet-bal-label">🪙 KVNC</span>
                        <span class="wallet-bal-val" id="tonKvncBalance">0 KVNC</span>
                    </div>
                </div>
                <div id="ton-connect-wallet"></div>
            </div>
            <div class="wallet-info-card">
                <div class="wallet-info-title">ℹ️ Kako koristiti</div>
                <div class="wallet-info-text">1. Klikni gumb iznad za spajanje TON walleta</div>
                <div class="wallet-info-text">2. Potvrdi u Telegram Wallet ili Tonkeeper</div>
                <div class="wallet-info-text">3. Wallet adresa se automatski sprema za isplate</div>
                <div class="wallet-info-text">4. Isplati KVNC s komandom /withdraw u botu</div>
            </div>
        </div>

        <!-- TAB: WALLET -->    </div>
    <script src="https://unpkg.com/@tonconnect/ui@latest/dist/tonconnect-ui.min.js"></script>
    <script src="app.js?v=5"></script>
</body>
</html>
        <!-- TAB: SPIN -->
        <div class="tab-content" id="tab-spin">
            <div class="spin-container">
                <h2 class="spin-title">🎡 Kotač sreće</h2>
                <p class="spin-desc">Svaki dan imaš jedan besplatni spin!</p>
                <div class="spin-wheel" id="spinWheel">
                    <div class="wheel-segments" id="wheelSegments">
                        <div class="segment" style="--i:1;--color:#ffd700;">💰</div>
                        <div class="segment" style="--i:2;--color:#ff6b35;">⚡</div>
                        <div class="segment" style="--i:3;--color:#00d4ff;">🎨</div>
                        <div class="segment" style="--i:4;--color:#ffd700;">💰</div>
                        <div class="segment" style="--i:5;--color:#ff6b35;">⚡</div>
                        <div class="segment" style="--i:6;--color:#00ff88;">🎨</div>
                        <div class="segment" style="--i:7;--color:#ffd700;">💰</div>
                        <div class="segment" style="--i:8;--color:#ff4466;">😅</div>
                    </div>
                    <div class="spin-pointer">▼</div>
                </div>
                <button class="spin-btn" id="spinBtn" onclick="spinWheel()">🎡 VRTI!</button>
                <div class="spin-result" id="spinResult"></div>
                <div class="spin-timer" id="spinTimer">⏳ Provjera...</div>
            </div>
        </div>
        <!-- TAB: SPIN -->
        <div class="tab-content" id="tab-spin">
            <div class="spin-container">
                <h2 class="spin-title">🎡 Kotač sreće</h2>
                <p class="spin-desc">Svaki dan imaš jedan besplatni spin!</p>
                <div class="spin-wheel" id="spinWheel">
                    <div class="wheel-segments" id="wheelSegments">
                        <div class="segment" style="--i:1;--color:#ffd700;">💰</div>
                        <div class="segment" style="--i:2;--color:#ff6b35;">⚡</div>
                        <div class="segment" style="--i:3;--color:#00d4ff;">🎨</div>
                        <div class="segment" style="--i:4;--color:#ffd700;">💰</div>
                        <div class="segment" style="--i:5;--color:#ff6b35;">⚡</div>
                        <div class="segment" style="--i:6;--color:#00ff88;">🎨</div>
                        <div class="segment" style="--i:7;--color:#ffd700;">💰</div>
                        <div class="segment" style="--i:8;--color:#ff4466;">😅</div>
                    </div>
                    <div class="spin-pointer">▼</div>
                </div>
                <button class="spin-btn" id="spinBtn" onclick="spinWheel()">🎡 VRTI!</button>
                <div class="spin-result" id="spinResult"></div>
                <div class="spin-timer" id="spinTimer">⏳ Provjera...</div>
            </div>
        </div>
        <!-- TAB: SPIN -->
        <div class="tab-content" id="tab-spin">
            <div class="spin-container">
                <h2 class="spin-title">🎡 Kotač sreće</h2>
                <p class="spin-desc">Svaki dan imaš jedan besplatni spin!</p>
                <div class="spin-wheel" id="spinWheel">
                    <div class="wheel-segments" id="wheelSegments">
                        <div class="segment" style="--i:1;--color:#ffd700;">💰</div>
                        <div class="segment" style="--i:2;--color:#ff6b35;">⚡</div>
                        <div class="segment" style="--i:3;--color:#00d4ff;">🎨</div>
                        <div class="segment" style="--i:4;--color:#ffd700;">💰</div>
                        <div class="segment" style="--i:5;--color:#ff6b35;">⚡</div>
                        <div class="segment" style="--i:6;--color:#00ff88;">🎨</div>
                        <div class="segment" style="--i:7;--color:#ffd700;">💰</div>
                        <div class="segment" style="--i:8;--color:#ff4466;">😅</div>
                    </div>
                    <div class="spin-pointer">▼</div>
                </div>
                <button class="spin-btn" id="spinBtn" onclick="spinWheel()">🎡 VRTI!</button>
                <div class="spin-result" id="spinResult"></div>
                <div class="spin-timer" id="spinTimer">⏳ Provjera...</div>
            </div>
        </div>
